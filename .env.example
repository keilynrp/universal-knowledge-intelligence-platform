# ─────────────────────────────────────────────────────────────
# UKIP Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# ── Authentication ──────────────────────────────────────────
# Admin credentials for the single-user JWT login
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
# Docker Compose users: bcrypt hashes contain "$". Escape them as "$$" in .env
# or prefer ADMIN_PASSWORD to avoid interpolation issues.
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# JWT signing key — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Token lifetime in minutes (default: 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ── Credential Encryption ───────────────────────────────────
# Fernet key for encrypting API keys/secrets stored in the database.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to skip encryption (DEV ONLY — do NOT use in production).
ENCRYPTION_KEY=

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3000

# ── Database ────────────────────────────────────────────────
# PostgreSQL-first default for local and deployment-oriented environments.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ukip
POSTGRES_USER=ukip
POSTGRES_PASSWORD=ukip_secret
DATABASE_URL=postgresql+psycopg2://ukip:ukip_secret@127.0.0.1:5432/ukip

# Docker Compose uses these separate variables so container networking does not
# accidentally inherit localhost/127.0.0.1 from host development settings.
DOCKER_POSTGRES_HOST=postgres
DOCKER_POSTGRES_PORT=5432
DOCKER_POSTGRES_DB=ukip
DOCKER_POSTGRES_USER=ukip
DOCKER_POSTGRES_PASSWORD=ukip_secret
# Optional: use this when the container should connect to an external DB host.
DOCKER_DATABASE_URL=

# Optional local SQLite fallback for compatibility-only scenarios.
# UKIP_DB_MODE=sqlite
# SQLITE_DATABASE_URL=sqlite:///./sql_app.db

# PostgreSQL/MySQL Pool Settings (ignored for SQLite fallback)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Session Cookie (separate from JWT for defense-in-depth) ─
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ── External Enrichment APIs ────────────────────────────────
WOS_API_KEY=
OPENALEX_EMAIL=
SCOPUS_API_KEY=
OPENAI_API_KEY=

# Optional experiment: LLM query reformulation for hard author-NIL cases.
# Keep disabled by default; deterministic retrieval remains the main path.
UKIP_ENABLE_LLM_QUERY_REFORMULATION=0
UKIP_LLM_QUERY_REFORMULATION_MODEL=gpt-4o-mini
UKIP_LLM_QUERY_REFORMULATION_MAX_VARIANTS=3
SCHOLAR_ENABLED=0
SCHOLAR_USE_FREE_PROXIES=0

# Scientific connector cascade — comma-separated provider IDs in priority order.
# Available: scopus, wos, openalex, crossref, pubmed, semantic_scholar, dblp, scholar
# Leave empty for default: scopus,wos,openalex,crossref,pubmed,semantic_scholar,dblp,scholar
ENRICHMENT_CASCADE=

# Semantic Scholar API key (optional; raises rate limit from 100/5min to higher)
S2_API_KEY=

# NCBI/PubMed API key (optional; raises rate limit from 3/s to 10/s)
NCBI_API_KEY=

# DBLP mirror URL (optional; leave empty for official dblp.org)
DBLP_MIRROR=

# ── SSO / OAuth2 (optional — leave blank to disable SSO button) ─
FRONTEND_URL=http://localhost:3004
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_METADATA_URL=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# Explicit opt-in only. Keep Sentry disabled unless intentionally enabled.
SENTRY_ENABLED=0
SENTRY_DSN=

# Tracing stays off even when Sentry is enabled until you opt in separately.
SENTRY_ENABLE_TRACING=0
SENTRY_TRACES_SAMPLE_RATE=0.0

# Conservative defaults to avoid surprise data capture.
SENTRY_SEND_DEFAULT_PII=0
SENTRY_RELEASE=
SENTRY_DEBUG=0

# Dokploy / production-oriented deployment references
# Frontend: https://ukip.inbounduxd.com
# API:      https://api.ukip.inbounduxd.com
NEXT_PUBLIC_API_URL=https://api.ukip.inbounduxd.com
DOCKER_FRONTEND_API_URL=http://ukip-backend:8000
RUN_DB_MIGRATIONS_ON_START=0

# ── Rust Engine Delegation ────────────────────────────────
# gRPC URL for the Rust compute engine (leave empty to disable)
ENGINE_GRPC_URL=
# Set to "1" to use TLS for gRPC connections to the engine.
# REQUIRED for production when engine runs on a different host.
# When disabled, credentials are sent in plaintext (dev only).
ENGINE_GRPC_TLS=0
# Bearer token for authenticating gRPC calls to the engine.
# Must match ENGINE_AUTH_TOKEN on the Rust engine side.
# If unset, gRPC endpoints on the engine are unauthenticated.
ENGINE_AUTH_TOKEN=
# Minimum unique-value count before delegating disambiguation/normalization
# to the engine. Below this threshold, Python handles it locally.
ENGINE_DELEGATION_THRESHOLD=100

# ── Distributed cache (Redis) ────────────────────────────────────────────────
# Optional. Unset => in-process caches (single-process only; today's behavior).
# Set to a managed Redis URL to enable cross-worker, deploy-surviving caching.
REDIS_URL=
UKIP_CACHE_PREFIX=ukip
# Fail-open timeouts (seconds) — keep small so Redis hiccups don't stall requests.
UKIP_CACHE_CONNECT_TIMEOUT=0.5
UKIP_CACHE_SOCKET_TIMEOUT=0.5
