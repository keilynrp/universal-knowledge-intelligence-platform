# UKIP pilot production environment for Dokploy
# Copy the relevant values into Dokploy's environment UI.

# ── Images (pin to a SHA tag for the first pilot) ───────────────────────────
UKIP_BACKEND_IMAGE=ghcr.io/OWNER/ukip-backend:sha-REPLACE_ME
UKIP_FRONTEND_IMAGE=ghcr.io/OWNER/ukip-frontend:sha-REPLACE_ME
UKIP_ENGINE_IMAGE=ghcr.io/OWNER/ukip-engine:sha-REPLACE_ME

# ── Domains ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://ukip.example.org
NEXT_PUBLIC_API_URL=https://api.ukip.example.org

# ── Database ─────────────────────────────────────────────────────────────────
# Use the connection string provided by the Dokploy-managed PostgreSQL service.
DATABASE_URL=postgresql+psycopg2://ukip:CHANGE_ME@postgres:5432/ukip
ENGINE_DATABASE_URL=postgresql://ukip:CHANGE_ME@postgres:5432/ukip
RUN_DB_MIGRATIONS_ON_START=1

# ── Bootstrap admin ──────────────────────────────────────────────────────────
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_PASSWORD_HASH=

# ── Required secrets ─────────────────────────────────────────────────────────
# JWT secret: long random string, 32+ chars minimum
JWT_SECRET_KEY=CHANGE_ME
# Session secret: long random string, 32+ chars minimum
SESSION_SECRET_KEY=CHANGE_ME
# Fernet key: URL-safe base64 32-byte key
ENCRYPTION_KEY=CHANGE_ME
ENGINE_AUTH_TOKEN=CHANGE_ME

# ── Logging / runtime ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
ENGINE_LOG_LEVEL=info
ENGINE_GRPC_PORT=50051
ENGINE_SYNC_THRESHOLD=500
ENGINE_SHADOW_MODE=false
ENGINE_FALLBACK_PYTHON=true
ENGINE_MAX_CONCURRENT_JOBS=4

# ── Recommended pilot-safe flags ────────────────────────────────────────────
SENTRY_ENABLED=0
SENTRY_DSN=
SENTRY_ENABLE_TRACING=0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=0
SENTRY_RELEASE=
SENTRY_DEBUG=0

SCHOLAR_USE_FREE_PROXIES=0
UKIP_ENABLE_LLM_QUERY_REFORMULATION=0
UKIP_LLM_QUERY_REFORMULATION_MODEL=gpt-4o-mini
UKIP_LLM_QUERY_REFORMULATION_MAX_VARIANTS=3

# ── Optional integrations ───────────────────────────────────────────────────
OPENALEX_EMAIL=
WOS_API_KEY=
SCOPUS_API_KEY=
OPENAI_API_KEY=
